DATABASE_URL=postgresql://postgres:postgres@localhost:5432/brokerflow
REDIS_URL=redis://localhost:6379
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d
ANTHROPIC_API_KEY=sk-ant-...
SENDGRID_API_KEY=SG.xxx
SENDGRID_FROM_EMAIL=notifications@yourbrokerage.com
INBOUND_EMAIL_WEBHOOK_SECRET=your-webhook-secret
GOOGLE_OAUTH_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=xxx
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/import/email/oauth/callback
MICROSOFT_OAUTH_CLIENT_ID=xxx
MICROSOFT_OAUTH_CLIENT_SECRET=xxx
MICROSOFT_OAUTH_REDIRECT_URI=http://localhost:3000/api/import/email/oauth/callback
STORAGE_PROVIDER=azure_blob
STORAGE_BUCKET=brokerflow-attachments
API_PORT=3001
WEB_PORT=3000
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000
NODE_ENV=development
LOG_LEVEL=debug

# Azure (deployment)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
AZURE_STORAGE_CONTAINER=brokerflow-attachments
AZURE_REGISTRY_NAME=brokerflowacr
AZURE_RESOURCE_GROUP=brokerflow-rg
