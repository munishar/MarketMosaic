{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@marketmosaic/shared": ["./packages/shared/src"],
      "@marketmosaic/shared/*": ["./packages/shared/src/*"],
      "@marketmosaic/db": ["./packages/db/src"],
      "@marketmosaic/manifest": ["./packages/manifest/src"],
      "@marketmosaic/manifest/*": ["./packages/manifest/src/*"]
    }
  },
  "references": [
    { "path": "./packages/shared" },
    { "path": "./packages/db" },
    { "path": "./packages/manifest" },
    { "path": "./apps/web" },
    { "path": "./apps/api" }
  ],
  "exclude": ["node_modules", "dist", "build"]
}
